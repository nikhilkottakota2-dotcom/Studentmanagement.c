#include<stdio.h>
#include<stdlib.h>
#include<string.h>

int count = 0;

struct std {
    int id;
    char name[50];
    int marks;
};

struct std *s = NULL;

void addstd() {
    count++;

    s = realloc(s, count * sizeof(struct std));

    printf("Enter id: ");
    scanf("%d", &s[count-1].id);

    printf("Enter name: ");
    scanf("%s", s[count-1].name);

    printf("Enter marks: ");
    scanf("%d", &s[count-1].marks);
}

void details() {
    int i;

    if(count == 0) {
        printf("__No students__\n");
    }
    else {
        for(i = 0; i < count; i++) {
            printf("ID: %d\n", s[i].id);
            printf("Name: %s\n", s[i].name);
            printf("Marks: %d\n", s[i].marks);
            printf("----------------\n");
        }
    }
}

int main() {
    int b;
    int a;
for(b = 0;b<= 12;b++){
    printf("1. Enter 1 for adding students\n");
    printf("2. Enter 2 for details of students\n");

    scanf("%d", &a);

    switch(a) {
        case 1:
            addstd();
            break;

        case 2:
            details();
            break;

        default:
            printf("====== Invalid option ======\n");
    }
    
}

    return 0;
}