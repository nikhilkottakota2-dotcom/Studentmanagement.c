#include<stdio.h>
#include<stdlib.h>
#include<string.h>

int count = 0;

struct std {
    int id;
    char name[50];
    int marks;
    char phon[15];
    char mail[30];
};

struct std *s = NULL;

void addstd() {
    count++;

    s = realloc(s, count * sizeof(struct std));

    printf("Enter id: ");
    scanf("%d", &s[count-1].id);

    (void)getchar();

    printf("Enter name: ");
    fgets(s[count-1].name,50,stdin);
    s[count-1].name[strcspn(s[count-1].name,"\n")] = 0;

    printf("Enter marks: ");
    scanf("%d", &s[count-1].marks);

    printf("Enter phone number: ");
    scanf("%s",s[count-1].phon);

    printf("Enter mail: ");
    scanf("%s",s[count-1].mail);
}

void details() {
    int i;

    if(count == 0) {
        printf("__No students__\n");
    }
    else {
        for(i = 0; i < count; i++) {

            printf("ID: %d\n", s[i].id);
            printf("Name: %s\n", s[i].name);
            printf("Marks: %d\n", s[i].marks);
            printf("Phone: %s\n",s[i].phon);
            printf("Mail: %s\n",s[i].mail);
            printf("----------------\n");

        }
    }
}

void search(){
    int d;
    char nam[50];
    int found = 0;

    printf("Enter name to search: ");
    (void)getchar();
    fgets(nam,50,stdin);
    nam[strcspn(nam,"\n")] = 0;

    for(d=0; d<count; d++){

        if(strstr(nam,s[d].name)==0){

            printf("Name of the student: %s\n",s[d].name);
            printf("Roll no: %d\n",s[d].id);
            printf("Marks: %d\n",s[d].marks);
            printf("Phone: %s\n",s[d].phon);
            printf("Mail: %s\n",s[d].mail);

            found = 1;
        }
    }

    if(found == 0){
        printf("Student not found\n");
    }
}

void edit(){

    int n,e,ma;
    char na[50];
    int found = 0;

    (void)getchar();

    printf("Enter name to search: ");
    fgets(na,50,stdin);
    na[strcspn(na,"\n")] = 0;

    for(e=0;e<count;e++){

        if(strcmp(na,s[e].name)==0){

            printf("Name of the student: %s\n",s[e].name);
            printf("Roll no: %d\n",s[e].id);
            printf("Marks: %d\n",s[e].marks);
            printf("Phone: %s\n",s[e].phon);
            printf("Mail: %s\n",s[e].mail);

            printf("\n1. Edit Name\n2. Edit Marks\n");
            printf("Enter option: ");
            scanf("%d",&n);

            switch(n){

            case 1:

                (void)getchar();

                printf("Enter new name: ");
                fgets(na,50,stdin);
                na[strcspn(na,"\n")] = 0;

                strcpy(s[e].name,na);

                printf("Name edited: %s\n",s[e].name);

                break;

            case 2:

                printf("Enter new marks: ");
                scanf("%d",&ma);

                s[e].marks = ma;

                printf("Marks edited: %d\n",s[e].marks);

                break;

            default:
                printf("Invalid option\n");
            }

            found = 1;
        }
    }

    if(found == 0){
        printf("Student not found\n");
    }
}

int main() {

    int a;

    while(1){

        printf("\n1. Add Student\n");
        printf("2. Show Details\n");
        printf("3. Search Student\n");
        printf("4. Edit Student\n");
        printf("5. Exit\n");

        printf("Enter option: ");
        scanf("%d", &a);

        switch(a) {
                                                                                                                                                                                                                                case 1:
            addstd();
            break;

        case 2:
            details();
            break;

        case 3:
            search();
            break;

        case 4:
            edit();
            break;

        case 5:
            return 0;

        default:
            printf("====== Invalid option ======\n");
        }
    }

    return 0;
}