#include<stdio.h>
#include<stdlib.h>
#include<string.h>

int count = 0;

struct std {
    int id;
    char name[50];
    int marks;
};

struct std *s = NULL;

void addstd() {
    count++;

    s = realloc(s, count * sizeof(struct std));

    printf("Enter id: ");
    scanf("%d", &s[count-1].id);

    printf("Enter name: ");
    scanf("%s", s[count-1].name);

    printf("Enter marks: ");
    scanf("%d", &s[count-1].marks);
}

void details() {
    int i;

    if(count == 0) {                                                            printf("__No students__\n");                                        }
    else {
        for(i = 0; i < count; i++) {
            printf("ID: %d\n", s[i].id);
            printf("Name: %s\n", s[i].name);
            printf("Marks: %d\n", s[i].marks);
            printf("----------------\n");
        }
    }
}

void search(){
    int d;
    char nam[50];
    printf("Enter Name to Search:");
    scanf("%s",nam);
    for(d = 0;d<count;d++){
        if(strcmp(nam,s[d].name)==0){
            printf("Name: %s\n",s[d].name);
            printf("ID: %d\n",s[d].id);
            printf("Marks:%d\n",s[d].marks);
            printf("------------------------\n");
        }
    }
}
int main() {
    int a;
while(1){
    printf("1. Enter 1 for adding students\n");
    printf("2. Enter 2 for details of students\n");
    printf("3. Enter 3 for searching the student\n");
printf("4. Enter 4  to exit program\n");
    scanf("%d", &a);

    switch(a) {
        case 1:
            addstd();
            break;

        case 2:
            details();
            break;
        case 3:
        search();
        break;
        case 4:
        return 0;
        break;
        default:
            printf("====== Invalid option ======\n");
    }
}

    return 0;
}
